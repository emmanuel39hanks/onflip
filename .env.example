# --- x402 (payments on X Layer, eip155:196) ---
# Address that receives stakes + fees (your X Layer wallet)
X402_PAY_TO=
# USDT on X Layer
X402_ASSET=0x1E4a5963aBFD975d8c9021cE480b42188849D41d
# OKX facilitator (verify + settle)
OKX_X402_BASE=https://web3.okx.com/api/v6/pay/x402
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
# 1 = skip facilitator (local testing only; never in production)
DEV_MODE=1

# --- pricing (deterministic, published) ---
EDGE_BPS=700              # house edge on the multiplier (7%)
MAX_LEGS=6
MAX_STAKE_USD=50
MAX_MULTIPLIER=100
MAX_PAYOUT_USD=1000

# --- natural language -> legs (optional) ---
# 0G Compute Network (TEE-attested). Unset -> deterministic keyword parser.
ZEROG_API_KEY=
ZEROG_BASE_URL=https://router-api.0g.ai/v1
ZEROG_MODEL=deepseek-v4-pro
# abuse guard: max model-backed NL calls per day, across all callers
NL_DAILY_MODEL_BUDGET=200

PORT=8080
